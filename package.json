{
  "name": "aib_insurance_management",
  "version": "0.0.1",
  "description": "AIB Insurance Management Platform",
  "author": "VTGhub Team",
  "maintainers": [],
  "license": "MIT",
  "private": true,
  "repository": "https://github.com/vima-tech-house/aib-backend-backoffice.git",
  "scripts": {
    "start": "cross-env NODE_ENV=development nest start --watch",
    "start:dev": "nodemon",
    "start:debug": "nodemon --config nodemon-debug.json",
    "prestart:prod": "rimraf dist && tsc",
    "start:prod": "cross-env NODE_ENV=production node dist/main.js",
    "tscheck:w": "tsc -w",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "tslint --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "hmr": "node dist/server",
    "webpack": "webpack --config webpack.config.js",
    "deploy:local": "docker-compose --env-file .env.development up -d",
    "build": "tsc -p tsconfig.json",
    "db:create": "cross-env ts-node -r tsconfig-paths/register node_modules/sequelize-cli/lib/sequelize db:create",
    "db:drop": "cross-env ts-node -r tsconfig-paths/register node_modules/sequelize-cli/lib/sequelize db:drop",
    "migrate": "cross-env ts-node -r tsconfig-paths/register node_modules/sequelize-cli/lib/sequelize db:migrate",
    "migrate:single": "cross-env ts-node -r tsconfig-paths/register node_modules/sequelize-cli/lib/sequelize db:migrate --name",
    "undo-migrate": "cross-env ts-node -r tsconfig-paths/register node_modules/sequelize-cli/lib/sequelize db:migrate:undo:all",
    "seed": "cross-env ts-node -r tsconfig-paths/register node_modules/sequelize-cli/lib/sequelize db:seed:all",
    "seed:single": "cross-env ts-node -r tsconfig-paths/register node_modules/sequelize-cli/lib/sequelize db:seed --seed",
    "migrate:all": "yarn build && yarn undo-migrate && yarn migrate && yarn seed",
    "undo-seed": "cross-env ts-node -r tsconfig-paths/register node_modules/sequelize-cli/lib/sequelize db:seed:undo:all"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.0",
    "@nestjs/bull": "^11.0.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.1.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^11.0.5",
    "@nestjs/sequelize": "^11.0.0",
    "@nestjs/swagger": "^7.1.0",
    "@nestjs/websockets": "^11.0.5",
    "@types/morgan": "^1.9.9",
    "@types/sequelize": "^4.28.20",
    "axios": "^1.7.9",
    "bcrypt": "^5.1.1",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "date-fns": "^4.1.0",
    "express": "^4.21.2",
    "helmet": "^7.0.0",
    "joi": "^17.13.3",
    "morgan": "^1.10.0",
    "node-mailjet": "^6.0.6",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "sequelize": "^6.37.5",
    "sequelize-cli": "^6.6.2",
    "sequelize-typescript": "^2.1.6",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@nestjs/platform-socket.io": "^11.0.5",
    "@nestjs/testing": "^10.0.0",
    "@nestjs/websockets": "^11.0.5",
    "@types/bcrypt": "^5.0.2",
    "@types/bull": "^4.10.4",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.0",
    "@types/joi": "^17.2.3",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^3.0.9",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^10.0.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.3.1",
    "husky": "^8.0.3",
    "jest": "^29.5.0",
    "lint-staged": "^13.2.3",
    "nodemon": "^3.1.9",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tslint": "^6.1.3",
    "typescript": "^5.1.3",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4",
    "webpack-node-externals": "^3.0.0"
  }
}
